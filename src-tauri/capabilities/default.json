{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:default",
    {
      "identifier": "fs:allow-read",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "$AUDIO/**" },
        { "path": "$MUSIC/**" },
        { "path": "$DOCUMENT/**" }
      ]
    },
    {
      "identifier": "fs:allow-write",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "$AUDIO/**" },
        { "path": "$MUSIC/**" },
        { "path": "$DOCUMENT/**" }
      ]
    },
    "fs:allow-stat",
    "fs:allow-exists"
  ]
}
