{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Luminous",
  "version": "0.90.0",
  "identifier": "org.luminous.music",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Luminous",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": true,
        "transparent": false,
        "center": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDdDRDY5QzUxMjJGNjQ5Q0IKUldTWU0vQytnVG1tTXlWVnpPZm5zNkdFTHdCSU9ldGlDNG9ZUXZCVHR0dzVzK3FRTHJ0Vw==",
      "endpoints": [
        "https://github.com/esoltys/luminous/releases/latest/download/latest.json"
      ]
    }
  }
}
